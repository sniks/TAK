generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  WON
  LOST
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

enum UserRoleName {
  SUPER_ADMIN
  ADMIN
  CONTENT_MANAGER
}

enum EmailDeliveryStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  RETRYING
}

model User {
  id            String           @id @default(cuid())
  name          String
  email         String           @unique
  passwordHash  String?
  image         String?
  emailVerified DateTime?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  roles         UserRole[]
  sessions      Session[]
  accounts      Account[]
  assignments   LeadAssignment[]
  activities    LeadActivity[]
  notes         LeadNote[]
  followups     Followup[]
  blogPosts     BlogPost[]
  newsPosts     NewsPost[]
  caseStudies   CaseStudy[]
  stories       SuccessStory[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id          String           @id @default(cuid())
  name        UserRoleName      @unique
  description String?
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Service {
  id          String            @id @default(cuid())
  name        String            @unique
  slug        String            @unique
  description String
  serviceEmail String?
  serviceWhatsappNumber String?
  isActive    Boolean           @default(true)
  leads       Lead[]
  routing     LeadRoutingRule[]
  gallery     GalleryItem[]
}

model Lead {
  id              String           @id @default(cuid())
  requestId       String?          @unique
  fullName        String
  mobile          String
  whatsapp        String?
  email           String
  company         String?
  city            String
  message         String?
  submissionType  String           @default("callback")
  serviceId       String
  service         Service          @relation(fields: [serviceId], references: [id])
  servicePayload  Json
  consentAccepted Boolean
  status          LeadStatus       @default(NEW)
  source          String           @default("Website")
  ctaType         String?
  campaignData    Json?
  assignedMobile  String
  assignedEmail   String
  routingWhatsapp String?
  routingReason   String?
  emailStatus     EmailDeliveryStatus @default(PENDING)
  emailMessageId  String?
  emailProviderResponse Json?
  emailSentAt     DateTime?
  emailLastAttemptAt DateTime?
  emailRetryCount Int              @default(0)
  emailRetryHistory Json?
  emailLastError  String?
  emailNextRetryAt DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  assignments     LeadAssignment[]
  activities      LeadActivity[]
  notes           LeadNote[]
  followups       Followup[]

  @@index([status, createdAt])
  @@index([serviceId, city])
  @@index([assignedMobile])
  @@index([emailStatus, emailNextRetryAt])
  @@index([source, createdAt])
}

model LeadAssignment {
  id        String   @id @default(cuid())
  leadId    String
  userId    String?
  ownerName String?
  mobile    String
  email     String?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([mobile, createdAt])
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  userId    String?
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  userId    String?
  note      String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Followup {
  id        String   @id @default(cuid())
  leadId    String
  userId    String?
  type      String   @default("Initial Contact")
  status    String   @default("Pending")
  priority  String   @default("High")
  dueAt     DateTime
  notes     String
  ownerName String?
  assignedMobile String?
  assignedEmail String?
  completed Boolean  @default(false)
  completedAt DateTime?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([dueAt, completed])
  @@index([status, priority, dueAt])
}

model BlogPost {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  featuredImage    String?
  shortDescription String
  content          String
  tags             String[]
  metaTitle        String
  metaDescription  String
  canonicalUrl     String?
  authorId         String?
  publishDate      DateTime?
  status           PublishStatus @default(DRAFT)
  author           User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([status, publishDate])
}

model NewsPost {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  newsUrl          String?
  sourceName       String?
  featuredImage    String?
  shortDescription String
  content          String
  tags             String[]
  metaTitle        String
  metaDescription  String
  canonicalUrl     String?
  authorId         String?
  publishDate      DateTime?
  status           PublishStatus @default(DRAFT)
  author           User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([status, publishDate])
}

model CaseStudy {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  featuredImage    String?
  shortDescription String
  content          String
  tags             String[]
  metaTitle        String
  metaDescription  String
  canonicalUrl     String?
  authorId         String?
  publishDate      DateTime?
  status           PublishStatus @default(DRAFT)
  author           User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

model SuccessStory {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  featuredImage    String?
  shortDescription String
  content          String
  tags             String[]
  metaTitle        String
  metaDescription  String
  canonicalUrl     String?
  authorId         String?
  publishDate      DateTime?
  status           PublishStatus @default(DRAFT)
  author           User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

model GalleryItem {
  id        String   @id @default(cuid())
  title     String
  type      String
  url       String
  serviceId String?
  category  String
  createdAt DateTime @default(now())
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([category, createdAt])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  company   String?
  photo     String?
  rating    Int
  review    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([isActive, createdAt])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  mobile    String?
  message   String
  source    String   @default("Contact Page")
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model LeadRoutingRule {
  id             String   @id @default(cuid())
  serviceId      String?
  city           String?
  ownerName      String?
  assignedMobile String
  assignedWhatsapp String?
  assignedEmail  String?
  priority       Int      @default(100)
  isActive       Boolean  @default(true)
  service        Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, city, isActive])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}
